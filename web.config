<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!--
      ╔══════════════════════════════════════════════════════════════╗
      ║  LÍMITE DE IIS (primera capa, antes de llegar a tu app)     ║
      ║  maxAllowedContentLength está en BYTES.                     ║
      ║  2147483647 = int.MaxValue ≈ 2 GB (máximo que acepta IIS)   ║
      ║  Si la request lo supera, IIS devuelve HTTP 413 directo.    ║
      ║                                                              ║
      ║  IMPORTANTE:                                                 ║
      ║  - maxRequestLength  → ASP.NET clásico. NO aplica aquí.     ║
      ║  - maxJsonLength     → JavaScriptSerializer. NO existe en   ║
      ║                        .NET Core. No lo necesitas.          ║
      ║  El equivalente real en .NET Core 8 es MaxRequestBodySize   ║
      ║  configurado en Program.cs (ya lo tienes).                  ║
      ╚══════════════════════════════════════════════════════════════╝
    -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="2147483647" />
      </requestFiltering>
    </security>

    <handlers>
      <add name="aspNetCore"
           path="*"
           verb="*"
           modules="AspNetCoreModuleV2"
           resourceType="Unspecified" />
    </handlers>

    <!--
      processPath: "dotnet" para publicación framework-dependent.
      hostingModel: "inprocess" (recomendado, mismo proceso que IIS).
    -->
    <aspNetCore processPath="dotnet"
                arguments=".\CostManagementService.dll"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess" />

  </system.webServer>
</configuration>
